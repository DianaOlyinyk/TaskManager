<?xml version="1.0" encoding="utf-8"?>

<Page
    x:Class="TaskManager.UI.Pages.TaskDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="10">

            <TextBlock Text="{Binding Title}"
                   FontSize="28"
                   FontWeight="Bold"/>

            <TextBlock Text="{Binding Description}"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"/>

            <TextBlock Text="{Binding PriorityText}"
                   Margin="0,10,0,0"/>

            <TextBlock Text="{Binding DueDateText}"
                   Margin="0,5,0,0"/>

            <TextBlock Text="{Binding CompletedText}"
                   Margin="0,5,0,0"/>

            <TextBlock Text="{Binding OverdueText}"
                   Margin="0,5,0,0"/>

            <Button Content="Back"
                Click="Back_Click"
                Margin="0,20,0,0"/>

        </StackPanel>
    </ScrollViewer>


</Page>


