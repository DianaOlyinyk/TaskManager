<?xml version="1.0" encoding="utf-8"?>

<Page
    x:Class="TaskManager.UI.Pages.TaskDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TaskManager.UI.Pages">

    <StackPanel Padding="20">

        <TextBlock x:Name="TaskTitle" FontSize="28"/>
        <TextBlock x:Name="TaskDescription"/>
        <TextBlock x:Name="TaskPriority"/>
        <TextBlock x:Name="TaskDueDate"/>
        <TextBlock x:Name="TaskOverdue"/>
        <Button Content="Back" Click="Back_Click"/>

    </StackPanel>

</Page>

