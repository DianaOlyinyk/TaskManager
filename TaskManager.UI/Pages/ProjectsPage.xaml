<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TaskManager.UI.Pages.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Padding="24,24,24,12" Spacing="6">
            <TextBlock Text="Projects"
                       FontSize="30"
                       FontWeight="SemiBold" />
            <TextBlock Text="Open a project to view its details and tasks."
                       Opacity="0.7" />
        </StackPanel>
        <StackPanel Grid.Row="1"
                    Padding="24,0,24,12"
                    Spacing="8">
            <ProgressRing IsActive="{Binding IsBusy}" />
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="IndianRed"
                       TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Grid.Row="2"
                    Padding="24,0,24,12"
                    Spacing="12">
            <TextBox PlaceholderText="Search..."
                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 TextChanged="Search_TextChanged" />    
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox Width="180"
              ItemsSource="{Binding SortOptions}"
              SelectedItem="{Binding SelectedSortBy, Mode=TwoWay}"
              SelectionChanged="Sort_SelectionChanged" />
                <ComboBox x:Name="TypeFilterComboBox"
              Width="180"
              SelectionChanged="TypeFilter_SelectionChanged">
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="Educational" />
                    <ComboBoxItem Content="Work" />
                    <ComboBoxItem Content="Personal" />
                </ComboBox>
            </StackPanel>
            <Border Padding="16"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="LightGray"
                    Background="WhiteSmoke">
                <StackPanel Spacing="10">
                    <TextBlock Text="Add Project"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBox Header="Name"
                             Text="{Binding NewProjectName, Mode=TwoWay}" />
                    <TextBox Header="Description"
                             Text="{Binding NewProjectDescription, Mode=TwoWay}" />
                    <ComboBox Header="Type"
                              ItemsSource="{Binding ProjectTypes}"
                              SelectedItem="{Binding SelectedNewProjectType, Mode=TwoWay}" />
                    <Button Content="Add project"
                            HorizontalAlignment="Left"
                            Click="AddProject_Click" />
                </StackPanel>
            </Border>
        </StackPanel>
        <ListView Grid.Row="3"
                  Margin="24,0,24,24"
                  ItemsSource="{Binding Projects}"
                  SelectionChanged="ProjectsList_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16"
                            Margin="0,0,0,12"
                            CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="LightGray"
                            Background="WhiteSmoke">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Type}"
                                       Opacity="0.75" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Progress:"
                                           Opacity="0.75" />
                                <TextBlock Text="{Binding Progress}"
                                           Opacity="0.75" />
                                <TextBlock Text="%"
                                           Opacity="0.75" />
                            </StackPanel>
                            <Button Content="Delete"
                                    HorizontalAlignment="Left"
                                    Click="DeleteProject_Click" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>