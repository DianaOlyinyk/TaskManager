<?xml version="1.0" encoding="utf-8"?>

<Page
    x:Class="TaskManager.UI.Pages.ProjectDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TaskManager.UI.Pages">

    <StackPanel Padding="20">

        <TextBlock x:Name="ProjectTitle"
                   FontSize="28"/>

        <TextBlock x:Name="ProjectDescription"
                   Margin="0,10"/>

        <TextBlock x:Name="ProjectProgress"
                   Margin="0,10"/>

        <TextBlock Text="Tasks"
                   FontSize="20"
                   Margin="0,20"/>

        <ListView x:Name="TasksList" SelectionChanged="TasksList_SelectionChanged"/>

        <Button Content="Back"
                Margin="0,20,0,0"
                Click="Back_Click"/>

    </StackPanel>

</Page>
